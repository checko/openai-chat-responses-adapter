# Bind / port
ADAPTER_BIND=127.0.0.1
ADAPTER_PORT=18891

# Client-facing bearer token. MUST be replaced before exposing beyond localhost.
ADAPTER_TOKEN=change-me

# Upstream /v1/responses sidecar (existing openai-passthrough)
RESPONSES_UPSTREAM_URL=http://127.0.0.1:18890/v1/responses
RESPONSES_UPSTREAM_TOKEN=change-me-upstream-token

# Limits
ADAPTER_MAX_BODY_BYTES=10485760
ADAPTER_REQUEST_TIMEOUT_MS=300000

# Logging: debug | info | warn | error
ADAPTER_LOG_LEVEL=info

# Health endpoint on/off
ADAPTER_ENABLE_HEALTH=1

# 0 = silently drop unsupported Chat Completions fields (default)
# 1 = reject unsupported fields with 400 invalid_request_error
ADAPTER_STRICT_OPENAI_COMPAT=0
